/* app.wxss 全局样式 */
page {
  background: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  color: #333;
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.primary-btn {
  background: #3a7afe;
  color: #fff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

.primary-btn[disabled] {
  background: #9fbdff;
  color: #fff;
}

.link-text {
  color: #3a7afe;
  font-size: 28rpx;
}
