<!--pages/index/index.wxml-->
<view class="container page-with-nav">
  <view class="top-bar">
    <view class="hello">Hi, {{username}}</view>
    <text class="logout" bindtap="logout">退出</text>
  </view>

  <view class="search-row">
    <view class="search-box">
      <text class="search-icon">搜</text>
      <input
        class="search-input"
        type="text"
        confirm-type="search"
        placeholder="搜索标题与描述"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
    </view>
    <button class="publish-mini" size="mini" bindtap="goPublish">发布</button>
  </view>

  <scroll-view class="status-tabs" scroll-x="true" show-scrollbar="false">
    <view class="tabs-row">
      <view
        wx:for="{{statusTabs}}"
        wx:key="id"
        class="chip chip-status {{statusTab === item.id ? 'chip-on' : ''}}"
        data-id="{{item.id}}"
        bindtap="onPickStatusTab"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <scroll-view class="loc-tabs" scroll-x="true" show-scrollbar="false">
    <view class="tabs-row tabs-row-loc">
      <view
        wx:for="{{locationTabs}}"
        wx:key="id"
        class="chip chip-loc {{locTab === item.id ? 'chip-on' : ''}}"
        data-id="{{item.id}}"
        bindtap="onPickLocTab"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{itemsEmpty && !loading}}" class="empty-banner">
    暂无失物记录，点击「发布」发一条
  </view>
  <view wx:elif="{{filteredEmpty && !loading}}" class="empty-banner empty-banner-muted">
    没有符合当前筛选的条目，试试调整分类或清空搜索
  </view>

  <view class="feed">
    <view class="list" wx:if="{{displayItems.length > 0}}">
      <view class="card" wx:for="{{displayItems}}" wx:key="id">
        <view class="card-head">
          <view class="card-title-wrap">
            <text class="post-tag post-tag-{{item.postType === '寻物' ? 'lost' : 'found'}}">{{item.postType}}</text>
            <text class="card-title">{{item.title}}</text>
          </view>
          <view class="status status-{{item.status === '已认领' ? 'done' : 'open'}}">
            {{item.status}}
          </view>
        </view>

        <view wx:if="{{item.publisherStudentVerified}}" class="cert-row">
          <text class="cert-badge">已通过学生认证</text>
        </view>

        <view wx:if="{{item.locationLabel}}" class="card-loc">{{item.locationLabel}}</view>

        <view class="card-desc">{{item.description}}</view>

        <image
          wx:if="{{item.imageUrl}}"
          class="card-image"
          src="{{item.imageUrl}}"
          mode="aspectFill"
          lazy-load="true"
        />

        <view class="card-foot">
          <text class="time">{{item.createTime}}</text>
          <button
            class="claim-btn claim-btn-{{item.status === '已认领' ? 'disabled' : 'active'}}"
            size="mini"
            disabled="{{item.status === '已认领'}}"
            data-id="{{item.id}}"
            data-status="{{item.status}}"
            bindtap="goClueSubmit"
          >
            {{item.status === '已认领' ? '已闭环' : (item.postType === '寻物' ? '我可能捡到了' : '我可能是失主')}}
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="bottom-nav-item bottom-nav-item-accent" bindtap="goHome">
      <text class="bottom-nav-text">首页</text>
    </view>
    <view class="bottom-nav-item" bindtap="goProfile">
      <text class="bottom-nav-text">我的</text>
    </view>
  </view>
</view>
