/* pages/publish/publish.wxss */
.page-with-nav {
  padding-bottom: 140rpx;
}
.draft-banner {
  font-size: 24rpx;
  color: #e65100;
  background: #fff3e0;
  padding: 16rpx 24rpx;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #222;
  margin-top: 40rpx;
}
.page-tip {
  font-size: 26rpx;
  color: #888;
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
}

.type-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.type-opt {
  font-size: 26rpx;
  color: #555;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e4e6eb;
  border-radius: 12rpx;
  background: #fafbfc;
}
.type-opt-active {
  border-color: #3a7afe;
  color: #3a7afe;
  background: #e8f1ff;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e4e6eb;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafbfc;
}

.loc-field {
  position: relative;
  z-index: 2;
}
.loc-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
  line-height: 1.4;
}
.map-pick-btn {
  margin-top: 16rpx;
  width: 100%;
  font-size: 26rpx !important;
  background: #fff !important;
  color: #1565c0 !important;
  border: 2rpx solid #90caf9 !important;
  border-radius: 12rpx !important;
}
.loc-input {
  position: relative;
  z-index: 2;
}
.loc-suggest {
  position: absolute;
  left: 0;
  right: 0;
  top: 100%;
  margin-top: 8rpx;
  max-height: 420rpx;
  background: #fff;
  border: 2rpx solid #e4e6eb;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 10;
  box-sizing: border-box;
}
.loc-suggest-item {
  padding: 18rpx 22rpx;
  border-bottom: 2rpx solid #f3f4f6;
}
.loc-suggest-item:last-child {
  border-bottom: none;
}
.loc-suggest-main {
  display: block;
  font-size: 28rpx;
  color: #222;
}
.loc-suggest-sub {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}
.loc-picked {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #2e7d32;
}
.loc-picked-text {
  flex: 1;
  margin-right: 16rpx;
}
.loc-picked-clear {
  color: #3a7afe;
  flex-shrink: 0;
}

.textarea {
  width: 100%;
  height: 220rpx;
  padding: 20rpx;
  border: 2rpx solid #e4e6eb;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafbfc;
}

/* ============================== 【本次新增】图片选择区 ============================== */
.image-picker {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #c8cdd4;
  border-radius: 10rpx;
  background: #fafbfc;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.image-picker-plus {
  font-size: 60rpx;
  color: #aaa;
  line-height: 1;
}
.image-picker-tip {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
}

.image-preview-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.image-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
}
.image-delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 32rpx;
  border-radius: 50%;
}

.submit-row {
  display: flex;
  gap: 20rpx;
  margin-top: 10rpx;
}
.ghost-btn {
  flex: 1;
  background: #fff !important;
  color: #3a7afe !important;
  border: 2rpx solid #3a7afe !important;
  font-size: 28rpx !important;
  border-radius: 12rpx !important;
}
.primary-btn-inline {
  flex: 1;
  margin-top: 0 !important;
}
.primary-btn {
  margin-top: 20rpx;
  width: 100%;
  background: #3a7afe !important;
  color: #fff !important;
  border: none !important;
  font-size: 30rpx !important;
  border-radius: 12rpx !important;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  background: #fff;
  border-top: 2rpx solid #e8eaed;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.bottom-nav-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #f5f6fa;
  margin: 0 12rpx;
}
.bottom-nav-item-accent {
  background: #e8f1ff;
}
.bottom-nav-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.bottom-nav-item-accent .bottom-nav-text {
  color: #3a7afe;
}
