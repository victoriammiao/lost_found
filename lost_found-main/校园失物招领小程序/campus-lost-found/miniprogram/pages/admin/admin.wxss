.container {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.tab-bar {
  display: flex;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #e4e7ec;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  color: #666;
  background: #f5f6fa;
}
.tab-on {
  background: #3a7afe;
  color: #fff;
  font-weight: 600;
}

.card-item .desc {
  white-space: pre-wrap;
  word-break: break-all;
}
.row-top {
  align-items: flex-start;
}
.actions-3 {
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12rpx;
}
.btn-del-admin {
  background: #fafafa !important;
  color: #666 !important;
  border: 2rpx solid #ddd !important;
}
.tip {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
  line-height: 1.5;
}
.empty {
  text-align: center;
  color: #aaa;
  font-size: 28rpx;
  padding: 80rpx 0;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}
.label {
  width: 120rpx;
  color: #888;
  flex-shrink: 0;
}
.val {
  flex: 1;
  color: #222;
  word-break: break-all;
}
.mono {
  font-family: monospace;
}
.actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed #eee;
}
.btn-reject {
  background: #fff5f5 !important;
  color: #c62828 !important;
  border: 2rpx solid #ffcdd2 !important;
}
.btn-ok {
  background: #3a7afe !important;
  color: #fff !important;
}

.clue-group {
  margin-bottom: 32rpx;
}
.clue-group-head {
  padding: 12rpx 4rpx 16rpx;
  border-bottom: 2rpx solid #e8eaed;
  margin-bottom: 12rpx;
}
.cg-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}
.cg-sub {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
  line-height: 1.4;
}
.clue-card {
  margin-bottom: 16rpx;
}
.clue-img {
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  margin: 12rpx 0 8rpx;
  background: #f0f0f0;
}
