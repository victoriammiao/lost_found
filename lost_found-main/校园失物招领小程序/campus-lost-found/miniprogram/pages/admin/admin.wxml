<view class="container">
  <view class="tab-bar">
    <view
      class="tab {{adminTab === 'verify' ? 'tab-on' : ''}}"
      data-tab="verify"
      bindtap="onSwitchTab"
    >学生认证</view>
    <view
      class="tab {{adminTab === 'items' ? 'tab-on' : ''}}"
      data-tab="items"
      bindtap="onSwitchTab"
    >失物待审</view>
    <view
      class="tab {{adminTab === 'clues' ? 'tab-on' : ''}}"
      data-tab="clues"
      bindtap="onSwitchTab"
    >线索</view>
  </view>

  <block wx:if="{{adminTab === 'verify'}}">
    <view class="tip">以下为待审核的学生认证申请
    （管理员账号：000）</view>
    <view wx:if="{{verifyList.length === 0 && !loading}}" class="empty">暂无待审核申请</view>
    <view wx:for="{{verifyList}}" wx:key="username" class="card">
      <view class="row">
        <text class="label">账号</text>
        <text class="val">{{item.username}}</text>
      </view>
      <view class="row">
        <text class="label">姓名</text>
        <text class="val">{{item.realName}}</text>
      </view>
      <view class="row">
        <text class="label">学号</text>
        <text class="val mono">{{item.studentNo}}</text>
      </view>
      <view class="actions">
        <button class="btn-reject" size="mini" data-u="{{item.username}}" bindtap="onRejectVerify">驳回</button>
        <button class="btn-ok" size="mini" data-u="{{item.username}}" bindtap="onApproveVerify">通过</button>
      </view>
    </view>
  </block>

  <block wx:elif="{{adminTab === 'items'}}">
    <view class="tip">以下为待审核的失物信息，通过后出现在首页</view>
    <view wx:if="{{itemList.length === 0 && !loading}}" class="empty">暂无待审核失物</view>
    <view wx:for="{{itemList}}" wx:key="id" class="card card-item">
      <view class="row">
        <text class="label">ID</text>
        <text class="val">{{item.id}}</text>
      </view>
      <view class="row">
        <text class="label">发布者</text>
        <text class="val">{{item.publisher}}</text>
      </view>
      <view class="row">
        <text class="label">类型</text>
        <text class="val">{{item.postType}}</text>
      </view>
      <view class="row">
        <text class="label">标题</text>
        <text class="val">{{item.title}}</text>
      </view>
      <view class="row row-top">
        <text class="label">描述</text>
        <text class="val desc">{{item.description}}</text>
      </view>
      <view class="row">
        <text class="label">地点</text>
        <text class="val">{{item.locationLabel}}</text>
      </view>
      <view class="row">
        <text class="label">发帖人联系</text>
        <text class="val mono">{{item.contact}}</text>
      </view>
      <view class="row">
        <text class="label">时间</text>
        <text class="val">{{item.createTime}}</text>
      </view>
      <view class="actions actions-3">
        <button class="btn-del-admin" size="mini" data-id="{{item.id}}" bindtap="onDeleteItem">删除</button>
        <button class="btn-reject" size="mini" data-id="{{item.id}}" bindtap="onRejectItem">拒绝</button>
        <button class="btn-ok" size="mini" data-id="{{item.id}}" bindtap="onApproveItem">通过</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="tip">同一失物下可有多条「捡到/失主」线索；以下联系方式仅管理员可见，请线下核对后再采纳。</view>
    <view wx:if="{{clueSections.length === 0 && !loading}}" class="empty">暂无待处理线索</view>
    <view wx:for="{{clueSections}}" wx:for-item="sec" wx:key="itemId" class="clue-group">
      <view class="clue-group-head">
        <text class="cg-title">{{sec.itemTitle}}</text>
        <text class="cg-sub">帖 ID {{sec.itemId}} · {{sec.itemPostType}} · 发布者 {{sec.itemPublisher}}</text>
        <text class="cg-sub">发帖人联系：{{sec.posterContact || '（未填）'}}</text>
      </view>
      <view wx:for="{{sec.clues}}" wx:for-item="c" wx:key="id" class="card clue-card">
        <view class="row">
          <text class="label">线索 ID</text>
          <text class="val">{{c.id}}</text>
        </view>
        <view class="row">
          <text class="label">提交人</text>
          <text class="val">{{c.submitter}}</text>
        </view>
        <view class="row">
          <text class="label">联系</text>
          <text class="val mono">{{c.contact}}</text>
        </view>
        <view class="row">
          <text class="label">地点</text>
          <text class="val">{{c.foundLocation}}</text>
        </view>
        <view class="row">
          <text class="label">时间</text>
          <text class="val">{{c.foundTime}}</text>
        </view>
        <view class="row row-top">
          <text class="label">说明</text>
          <text class="val desc">{{c.description}}</text>
        </view>
        <image wx:if="{{c.imageFullUrl}}" class="clue-img" src="{{c.imageFullUrl}}" mode="aspectFill" />
        <view class="actions">
          <button class="btn-reject" size="mini" data-id="{{c.id}}" bindtap="onRejectClue">拒绝</button>
          <button class="btn-ok" size="mini" data-id="{{c.id}}" bindtap="onMatchClue">采纳</button>
        </view>
      </view>
    </view>
  </block>
</view>
