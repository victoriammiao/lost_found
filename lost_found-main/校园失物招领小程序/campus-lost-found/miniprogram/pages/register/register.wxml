<!--pages/register/register.wxml-->
<view class="container">
  <view class="title">注册账号</view>
  <view class="subtitle">欢迎加入校园失物招领</view>

  <view class="form">
    <view class="form-item">
      <text class="label">账号</text>
      <input class="input"
             placeholder="请输入账号, 不少于2位"
             value="{{username}}"
             bindinput="onInputUsername" />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input"
             placeholder="请输入密码, 不少于4位"
             password="true"
             value="{{password}}"
             bindinput="onInputPassword" />
    </view>

    <button class="primary-btn"
            loading="{{loading}}"
            disabled="{{loading}}"
            bindtap="onRegister">注册</button>

    <view class="footer">
      <text>已有账号?</text>
      <text class="link-text" bindtap="goLogin">去登录</text>
    </view>
  </view>
</view>
