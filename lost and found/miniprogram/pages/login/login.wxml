<!--pages/login/login.wxml-->
<view class="container">
  <view class="title">校园失物招领</view>
  <view class="subtitle">登录后使用</view>

  <view class="form">
    <view class="form-item">
      <text class="label">账号</text>
      <input class="input"
             placeholder="请输入账号"
             value="{{username}}"
             bindinput="onInputUsername" />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input"
             placeholder="请输入密码"
             password="true"
             value="{{password}}"
             bindinput="onInputPassword" />
    </view>

    <button class="primary-btn"
            loading="{{loading}}"
            disabled="{{loading}}"
            bindtap="onLogin">登录</button>

    <view class="footer">
      <text>还没有账号?</text>
      <text class="link-text" bindtap="goRegister">去注册</text>
    </view>
  </view>
</view>
