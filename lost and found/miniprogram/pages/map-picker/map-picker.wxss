.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f6fa;
}
.map-wrap {
  flex: 1;
  width: 100%;
  min-height: 400rpx;
  position: relative;
}
.map {
  width: 100%;
  height: 100%;
}
/* map 内 cover-view：必须叠在原生地图上，点击才灵敏 */
.zoom-stack {
  position: absolute;
  right: 20rpx;
  bottom: 28rpx;
  display: flex;
  flex-direction: column;
  z-index: 999;
}
.zoom-fab {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 14rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.15);
}
.zoom-fab:last-child {
  margin-bottom: 0;
}
.zoom-fab-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
}
.panel {
  padding: 20rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #e8eaed;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.panel-tip {
  font-size: 26rpx;
  color: #444;
  line-height: 1.5;
  display: block;
  margin-bottom: 10rpx;
}
.panel-sub {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}
.btn-back {
  background: #f5f6fa !important;
  color: #555 !important;
  font-size: 28rpx !important;
}
