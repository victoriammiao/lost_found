.container {
  padding: 24rpx;
  padding-bottom: 48rpx;
}
.tip {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 24rpx;
  line-height: 1.5;
}
.empty {
  text-align: center;
  color: #aaa;
  font-size: 28rpx;
  padding: 80rpx 0;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}
.label {
  width: 120rpx;
  color: #888;
  flex-shrink: 0;
}
.val {
  flex: 1;
  color: #222;
  word-break: break-all;
}
.mono {
  font-family: monospace;
}
.actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed #eee;
}
.btn-reject {
  background: #fff5f5 !important;
  color: #c62828 !important;
  border: 2rpx solid #ffcdd2 !important;
}
.btn-ok {
  background: #3a7afe !important;
  color: #fff !important;
}
