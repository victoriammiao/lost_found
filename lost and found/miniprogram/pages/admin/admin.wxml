<view class="container">
  <view class="tip">以下为待审核的学生认证申请，管理员账号：000</view>

  <view wx:if="{{list.length === 0 && !loading}}" class="empty">暂无待审核申请</view>

  <view wx:for="{{list}}" wx:key="username" class="card">
    <view class="row">
      <text class="label">账号</text>
      <text class="val">{{item.username}}</text>
    </view>
    <view class="row">
      <text class="label">姓名</text>
      <text class="val">{{item.realName}}</text>
    </view>
    <view class="row">
      <text class="label">学号</text>
      <text class="val mono">{{item.studentNo}}</text>
    </view>
    <view class="actions">
      <button class="btn-reject" size="mini" data-u="{{item.username}}" bindtap="onReject">驳回</button>
      <button class="btn-ok" size="mini" data-u="{{item.username}}" bindtap="onApprove">通过</button>
    </view>
  </view>
</view>
