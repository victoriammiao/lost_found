/* pages/index/index.wxss */
/* 【升级】在 A 原有样式基础上新增搜索框、分类标签、状态分段、卡片分类标签等 */

/* ====== A 原有：底部导航 ====== */
.page-with-nav {
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  background: #fff;
  border-top: 2rpx solid #e8eaed;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.bottom-nav-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #f5f6fa;
  margin: 0 12rpx;
}
.bottom-nav-item-accent {
  background: #e8f1ff;
}
.bottom-nav-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.bottom-nav-item-accent .bottom-nav-text {
  color: #3a7afe;
}

/* ====== 顶部栏 ====== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 10rpx 20rpx;
}
.hello {
  font-size: 28rpx;
  color: #666;
}
.logout {
  font-size: 26rpx;
  color: #3a7afe;
}

.action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
}
.publish-btn {
  background: #3a7afe !important;
  color: #fff !important;
  border: none !important;
  font-size: 26rpx !important;
}

/* ====== 【新增】搜索框 ====== */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
  color: #aaa;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #222;
  height: 72rpx;
  line-height: 72rpx;
}
.search-placeholder {
  color: #b5b5b5;
  font-size: 28rpx;
}
.search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #d8d8d8;
  color: #fff;
  font-size: 28rpx;
  line-height: 36rpx;
  text-align: center;
  margin-left: 10rpx;
}

/* ====== 【新增】分类标签横向滚动 ====== */
.cat-scroll {
  white-space: nowrap;
  margin: 0 -30rpx 20rpx;
  padding: 0 30rpx;
}
.cat-list {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 20rpx;
}
.cat-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 26rpx;
  border-radius: 32rpx;
  background: #fff;
  color: #444;
  font-size: 26rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.cat-chip-active {
  background: #3a7afe;
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(58, 122, 254, 0.35);
}
.cat-icon {
  font-size: 26rpx;
}

/* ====== 【新增】状态分段 + 结果计数 ====== */
.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.seg {
  display: inline-flex;
  background: #ececf3;
  border-radius: 28rpx;
  padding: 4rpx;
}
.seg-item {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 24rpx;
}
.seg-item-active {
  background: #fff;
  color: #3a7afe;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}
.result-count {
  font-size: 24rpx;
  color: #999;
}

/* 【新增】激活筛选提示行 */
.active-filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff5e6;
  color: #c97a00;
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
}
.active-filter-text {
  flex: 1;
}
.reset-btn {
  color: #3a7afe;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
}

/* ====== 空状态 ====== */
.empty {
  text-align: center;
  margin-top: 120rpx;
}
.empty-emoji {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  color: #aaa;
  font-size: 28rpx;
  padding: 0 40rpx;
  line-height: 1.6;
}
.empty-action {
  display: inline-block;
  margin-top: 24rpx;
  color: #3a7afe;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border: 2rpx solid #3a7afe;
  border-radius: 30rpx;
}

/* ====== 列表卡片 ====== */
.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

/* A 原有：学生认证 */
.cert-row {
  margin-bottom: 10rpx;
}
.cert-badge {
  font-size: 22rpx;
  color: #2e7d32;
  background: #e8f5e9;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
}

/* A 原有：postType 标签 */
.card-title-wrap {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}
.post-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 8rpx;
}
.post-tag-lost {
  background: #fff3e0;
  color: #e65100;
}
.post-tag-found {
  background: #e8f5e9;
  color: #2e7d32;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}
.status-open {
  background: #e8f1ff;
  color: #3a7afe;
}
.status-done {
  background: #eeeeee;
  color: #999;
}

/* 【新增】分类小标签 */
.card-meta {
  margin-bottom: 10rpx;
}
.cat-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #6b7280;
  background: #f1f3f9;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

/* A 原有：地点标签 */
.card-loc {
  font-size: 26rpx;
  color: #1565c0;
  margin-bottom: 10rpx;
  padding: 10rpx 14rpx;
  background: #e3f2fd;
  border-radius: 8rpx;
  display: inline-block;
  max-width: 100%;
  box-sizing: border-box;
}

.card-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.card-image {
  width: 100%;
  height: 320rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
  margin-bottom: 16rpx;
  display: block;
}

.card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 2rpx dashed #f0f0f0;
  padding-top: 14rpx;
}
.time {
  font-size: 22rpx;
  color: #999;
}
.claim-btn {
  font-size: 24rpx !important;
  border: none !important;
}
.claim-btn-active {
  background: #3a7afe !important;
  color: #fff !important;
}
.claim-btn-disabled {
  background: #e0e0e0 !important;
  color: #999 !important;
}
