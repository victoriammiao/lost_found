/* pages/index/index.wxss */
.page-with-nav {
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  background: #fff;
  border-top: 2rpx solid #e8eaed;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.bottom-nav-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #f5f6fa;
  margin: 0 12rpx;
}
.bottom-nav-item-accent {
  background: #e8f1ff;
}
.bottom-nav-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.bottom-nav-item-accent .bottom-nav-text {
  color: #3a7afe;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 16rpx 16rpx;
}
.hello {
  font-size: 28rpx;
  color: #666;
}
.logout {
  font-size: 26rpx;
  color: #3a7afe;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 20rpx 16rpx;
}
.search-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  background: #f0f2f6;
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 72rpx;
  border: 2rpx solid #e4e7ec;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
}
.publish-mini {
  flex-shrink: 0;
  background: #3a7afe !important;
  color: #fff !important;
  border: none !important;
  font-size: 24rpx !important;
  margin: 0 !important;
}

.status-tabs,
.loc-tabs {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 8rpx;
}
.tabs-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  padding: 0 20rpx 12rpx;
  box-sizing: border-box;
}
.tabs-row-loc {
  padding-bottom: 16rpx;
}

.chip {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #555;
  background: #fff;
  border-radius: 999rpx;
  border: 2rpx solid #e4e7ec;
}
.chip:last-child {
  margin-right: 0;
}
.chip-on {
  color: #fff;
  background: #3a7afe;
  border-color: #3a7afe;
}
.chip-status {
  font-weight: 500;
}
.chip-loc {
  font-size: 24rpx;
  padding: 10rpx 22rpx;
}

.empty-banner {
  margin: 0 20rpx 16rpx;
  padding: 18rpx 22rpx;
  text-align: center;
  color: #888;
  font-size: 26rpx;
  line-height: 1.45;
  background: #fff9e6;
  border-radius: 12rpx;
  border: 1rpx solid #ffe0a3;
}
.empty-banner-muted {
  background: #f5f6fa;
  border-color: #e4e7ec;
  color: #777;
}

.feed {
  padding: 0 20rpx;
}

.section-empty {
  font-size: 26rpx;
  color: #bbb;
  text-align: center;
  padding: 40rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}
.cert-row {
  margin-bottom: 10rpx;
}
.cert-badge {
  font-size: 22rpx;
  color: #2e7d32;
  background: #e8f5e9;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.card-title-wrap {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}
.post-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 8rpx;
}
.post-tag-lost {
  background: #fff3e0;
  color: #e65100;
}
.post-tag-found {
  background: #e8f5e9;
  color: #2e7d32;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}
.status-open {
  background: #e8f1ff;
  color: #3a7afe;
}
.status-done {
  background: #eeeeee;
  color: #999;
}

.card-loc {
  font-size: 26rpx;
  color: #1565c0;
  margin-bottom: 10rpx;
  padding: 10rpx 14rpx;
  background: #e3f2fd;
  border-radius: 8rpx;
  display: inline-block;
  max-width: 100%;
  box-sizing: border-box;
}

.card-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.card-image {
  width: 100%;
  height: 320rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
  margin-bottom: 16rpx;
  display: block;
}

.card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 2rpx dashed #f0f0f0;
  padding-top: 14rpx;
}
.time {
  font-size: 22rpx;
  color: #999;
}
.claim-btn {
  font-size: 24rpx !important;
  border: none !important;
}
.claim-btn-active {
  background: #3a7afe !important;
  color: #fff !important;
}
.claim-btn-disabled {
  background: #e0e0e0 !important;
  color: #999 !important;
}
