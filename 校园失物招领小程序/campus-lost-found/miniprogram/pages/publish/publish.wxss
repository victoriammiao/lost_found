/* pages/publish/publish.wxss */
.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #222;
  margin-top: 40rpx;
}
.page-tip {
  font-size: 26rpx;
  color: #888;
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e4e6eb;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafbfc;
}

.textarea {
  width: 100%;
  height: 220rpx;
  padding: 20rpx;
  border: 2rpx solid #e4e6eb;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafbfc;
}

/* ============================== 【本次新增】图片选择区 ============================== */
.image-picker {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #c8cdd4;
  border-radius: 10rpx;
  background: #fafbfc;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.image-picker-plus {
  font-size: 60rpx;
  color: #aaa;
  line-height: 1;
}
.image-picker-tip {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
}

.image-preview-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.image-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
}
.image-delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 32rpx;
  border-radius: 50%;
}
