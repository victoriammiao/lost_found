.container {
  padding: 24rpx 24rpx 48rpx;
}
.admin-entry {
  border: 2rpx solid #3a7afe;
}
.btn-admin {
  width: 100%;
  background: #3a7afe !important;
  color: #fff !important;
  border: none !important;
  font-size: 28rpx !important;
  border-radius: 12rpx !important;
}
.admin-hint {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 16rpx;
  line-height: 1.4;
}

.verified-done {
  padding: 8rpx 0;
}
.verified-strong {
  font-size: 30rpx;
  font-weight: 600;
  color: #2e7d32;
}
.pending-tip {
  font-size: 26rpx;
  color: #e65100;
  line-height: 1.5;
  background: #fff3e0;
  padding: 20rpx;
  border-radius: 12rpx;
}
.reject-tip {
  font-size: 26rpx;
  color: #c62828;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.hello {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}
.badge-verified {
  font-size: 22rpx;
  color: #2e7d32;
  background: #e8f5e9;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
}
.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.sub {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
}

.verified-tip {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}

.form-row {
  margin-bottom: 20rpx;
}
.label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}
.input {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e4e6eb;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafbfc;
}
.btn-verify {
  margin-top: 10rpx;
  background: #3a7afe !important;
  color: #fff !important;
  border: none !important;
  font-size: 28rpx !important;
  border-radius: 12rpx !important;
}

.empty {
  font-size: 26rpx;
  color: #aaa;
  text-align: center;
  padding: 24rpx 0;
}

.item-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}
.item-row:last-child {
  border-bottom: none;
}
.item-main {
  flex: 1;
  min-width: 0;
}
.post-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 10rpx;
}
.post-tag-lost {
  background: #fff3e0;
  color: #e65100;
}
.post-tag-found {
  background: #e8f5e9;
  color: #2e7d32;
}
.item-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.mini-cert {
  font-size: 20rpx;
  color: #2e7d32;
  background: #e8f5e9;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}
.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #222;
}
.item-loc {
  display: block;
  font-size: 24rpx;
  color: #1565c0;
  margin-top: 8rpx;
}
.item-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
.btn-del {
  flex-shrink: 0;
  background: #fff5f5 !important;
  color: #c62828 !important;
  border: 2rpx solid #ffcdd2 !important;
}

.footer-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}
.btn-outline {
  flex: 1;
  background: #fff !important;
  color: #3a7afe !important;
  border: 2rpx solid #3a7afe !important;
  font-size: 28rpx !important;
  border-radius: 12rpx !important;
}
