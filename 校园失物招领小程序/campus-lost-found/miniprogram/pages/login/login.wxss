/* pages/login/login.wxss */
.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #222;
  margin-top: 80rpx;
  text-align: center;
}
.subtitle {
  font-size: 28rpx;
  color: #888;
  text-align: center;
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}

.api-debug {
  margin: 0 32rpx 28rpx;
  padding: 20rpx 24rpx;
  background: #f0f4ff;
  border-radius: 12rpx;
  border: 1rpx solid #d6e0ff;
}
.api-debug-label {
  display: block;
  font-size: 22rpx;
  color: #5a6fa8;
  margin-bottom: 8rpx;
}
.api-debug-url {
  display: block;
  font-size: 24rpx;
  color: #1a3a8a;
  word-break: break-all;
  line-height: 1.4;
}
.api-debug-tip {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-top: 12rpx;
  line-height: 1.45;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e4e6eb;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafbfc;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #888;
}
.footer .link-text {
  margin-left: 12rpx;
}
