<view class="container">
  <view class="header">
    <text class="hello">Hi，{{username}}</text>
    <text wx:if="{{profile && !profile.isAdmin && profile.studentVerified}}" class="badge-verified">已通过学生认证</text>
  </view>

  <!-- 管理员：仅工作台说明 + 进入后台（不展示学生认证 / 我的发布 / 草稿） -->
  <block wx:if="{{profile && profile.isAdmin}}">
    <view class="card admin-entry">
      <view class="card-title">管理后台</view>
      <view class="philosophy-block">
        <text class="philosophy-title">（账号 000）</text>
        <text class="philosophy-body">现实中常有多人同时「可能捡到」同一件失物。本小程序不采用「一键认领」，而是由热心同学提交线索（地点、时间、特征、联系方式仅管理员可见），管理员比对多条线索后再协助对接，降低骚扰与诈骗风险。</text>
      </view>
      <button class="btn-admin" bindtap="goAdminVerify">进入管理后台</button>
      <text class="admin-hint">失物帖审核、学生认证、线索采纳与拒绝</text>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="card-title">学生认证</view>

      <block wx:if="{{profile && profile.studentVerified}}">
        <view class="verified-done">
          <text class="verified-strong">已通过学生认证</text>
          <view class="verified-tip">姓名：{{profile.realName}} · 学号：{{profile.studentNoMasked}}</view>
        </view>
      </block>

      <block wx:elif="{{profile && profile.studentVerifyStatus === 'pending'}}">
        <view class="pending-tip">您的申请已提交，正在等待管理员审核，请耐心等待。</view>
      </block>

      <block wx:else>
        <view wx:if="{{profile && profile.studentVerifyStatus === 'rejected'}}" class="reject-tip">上次申请未通过，可修改信息后重新提交。</view>

        <view class="form-row">
          <text class="label">真实姓名</text>
          <input class="input" placeholder="与学籍一致" value="{{verifyName}}" bindinput="onVerifyName" />
        </view>
        <view class="form-row">
          <text class="label">学号</text>
          <input class="input" type="number" placeholder="学号" value="{{verifyNo}}" bindinput="onVerifyNo" />
        </view>
        <button class="btn-verify" loading="{{verifyLoading}}" disabled="{{verifyLoading}}" bindtap="onSubmitVerify">提交认证申请</button>
      </block>
    </view>

    <view class="card">
      <view class="card-title row-between">
        <text>我的发布</text>
        <text class="sub">未认领可删；待审/未通过也可删除</text>
      </view>
      <view wx:if="{{published.length === 0}}" class="empty">暂无已发布内容</view>
      <view wx:for="{{published}}" wx:key="id" class="item-row">
        <view class="item-main">
          <view class="item-tags">
            <text class="post-tag post-tag-{{item.postType === '寻物' ? 'lost' : 'found'}}">{{item.postType}}</text>
            <text wx:if="{{item.publisherStudentVerified}}" class="mini-cert">学生认证</text>
            <text class="review-badge review-{{item.reviewStatus}}">{{item.reviewLabel}}</text>
          </view>
          <text class="item-title">{{item.title}}</text>
          <text wx:if="{{item.locationLabel}}" class="item-loc">{{item.locationLabel}}</text>
          <text wx:if="{{item.contact}}" class="item-contact">我的联系方式：{{item.contact}}</text>
          <text class="item-meta">{{item.createTime}} · {{item.status}}</text>
        </view>
        <button class="btn-del" size="mini" data-id="{{item.id}}" bindtap="onDeletePublished">删除</button>
      </view>
    </view>

    <view class="card">
      <view class="card-title">草稿箱</view>
      <view wx:if="{{drafts.length === 0}}" class="empty">暂无草稿</view>
      <view wx:for="{{drafts}}" wx:key="id" class="item-row">
        <view class="item-main" bindtap="onEditDraft" data-id="{{item.id}}">
          <text class="item-title">{{item.title}}</text>
          <text wx:if="{{item.locationLabel}}" class="item-loc">{{item.locationLabel}}</text>
          <text class="item-meta">{{item.createTime}}</text>
        </view>
        <button class="btn-del" size="mini" data-id="{{item.id}}" catchtap="onDeleteDraft">删除</button>
      </view>
    </view>
  </block>

  <view class="footer-actions">
    <button wx:if="{{!profile.isAdmin}}" class="btn-outline" bindtap="goPublish">去发布</button>
    <button class="btn-outline" bindtap="goHome">回首页</button>
  </view>
</view>
