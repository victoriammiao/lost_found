<view class="container">
  <view wx:if="{{peek}}" class="peek-wrap">
  <view class="peek-card">
    <text class="peek-type post-tag-{{peek.postType === '寻物' ? 'lost' : 'found'}}">{{peek.postType}}</text>
    <text class="peek-title">{{peek.title}}</text>
    <text wx:if="{{peek.locationLabel}}" class="peek-loc">{{peek.locationLabel}}</text>
    <text class="peek-tip">你的联系方式仅管理员可见，用于核对身份、防止骚扰与诈骗。</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">你的联系方式 *</text>
      <input class="input input-line" placeholder="手机或微信号(至少3字)" maxlength="40" value="{{contact}}" bindinput="onInputContact" />
    </view>
    <view class="form-item">
      <text class="label">捡到/见到地点 *</text>
      <input
        class="input input-line"
        placeholder="可手写，或点下面地图选校园标注"
        maxlength="200"
        value="{{foundLocation}}"
        bindinput="onInputFoundLoc"
      />
      <button class="map-pick-btn" bindtap="goMapPickFound">地图选点（就近匹配标注）</button>
    </view>
    <view class="form-item">
      <text class="label">时间 *</text>
      <input class="input input-line" placeholder="例如：昨天下午4点左右" maxlength="80" value="{{foundTime}}" bindinput="onInputFoundTime" />
    </view>
    <view class="form-item">
      <text class="label">情况说明 *</text>
      <textarea class="textarea textarea-body" placeholder="外观、特征、如何捡到等，便于管理员与失主核对" maxlength="2000" value="{{description}}" bindinput="onInputDesc" />
    </view>
    <view class="form-item">
      <text class="label">图片（可选）</text>
      <view wx:if="{{!imagePath}}" class="img-placeholder" bindtap="onChooseImage">+ 添加图片</view>
      <view wx:else class="img-wrap">
        <image class="img-prev" src="{{imagePath}}" mode="aspectFill" bindtap="onPreview" />
        <text class="img-clear" bindtap="onClearImage">删除</text>
      </view>
    </view>
    <button class="submit" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmit">提交线索</button>
  </view>
  </view>
  <view wx:else class="peek-loading">加载中…</view>
</view>
