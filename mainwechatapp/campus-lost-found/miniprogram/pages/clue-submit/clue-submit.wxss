.container {
  padding: 24rpx 24rpx 48rpx;
}
.peek-loading {
  padding: 120rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #888;
}
.peek-card {
  background: #f0f4ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid #d6e0ff;
}
.peek-type {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}
.post-tag-lost {
  background: #fff3e0;
  color: #e65100;
}
.post-tag-found {
  background: #e8f5e9;
  color: #2e7d32;
}
.peek-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  display: block;
  margin-bottom: 8rpx;
}
.peek-loc {
  font-size: 26rpx;
  color: #1565c0;
  display: block;
  margin-bottom: 12rpx;
}
.peek-tip {
  font-size: 24rpx;
  color: #666;
  line-height: 1.45;
}
.form-item {
  margin-bottom: 28rpx;
}
.label {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
}
.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #fafbfc;
  border: 2rpx solid #e4e6eb;
  border-radius: 12rpx;
  padding: 26rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.45;
}
.input-line {
  min-height: 96rpx;
}
.textarea {
  min-height: 200rpx;
}
.textarea-body {
  min-height: 300rpx;
  line-height: 1.55;
}
.map-pick-btn {
  margin-top: 16rpx;
  width: 100%;
  font-size: 26rpx !important;
  background: #fff !important;
  color: #1565c0 !important;
  border: 2rpx solid #90caf9 !important;
  border-radius: 12rpx !important;
}
.img-placeholder {
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}
.img-wrap {
  position: relative;
}
.img-prev {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  background: #eee;
}
.img-clear {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}
.submit {
  margin-top: 16rpx;
  background: #3a7afe !important;
  color: #fff !important;
  border: none !important;
}
